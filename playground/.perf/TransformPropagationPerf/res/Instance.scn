@root = InstanceRoot

[InstanceRoot]
[Node3D]
    position = (0, 0, 0)
[/Node3D]
[/InstanceRoot]

[instance]
parent = @root
script = "res://scripts/instance.rs"
[MeshInstance3D]
    mesh = "__cube__"
    [Node3D]
        position = (0, 0, 0)
        scale = (0.3, 0.3, 0.3)
    [/Node3D]
[/MeshInstance3D]
[/instance]