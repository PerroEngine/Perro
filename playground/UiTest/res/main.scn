[/UiLayout]
[/right_layout]

[right_title]
parent = right_layout
[UiLabel]
    text = "VLayout"
    font_size = 22
    color = "#EDE7F6"
    size = (260, 42)
[/UiLabel]
[/right_title]

[right_chip_a]
parent = right_layout
[UiPanel]
