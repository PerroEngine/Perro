@root = ui_root

[ui_root]
name = "UI Test Root"
script = "res://scripts/script.rs"
[UiPanel]
    size_ratio = (1.0, 1.0)
    fill = "#151820"
    stroke = "#2E3440"
    stroke_width = 2
    corner_radius = 18
    padding = (0, 0, 0, 0)
[/UiPanel]
[/ui_root]

[top_bar]
parent = @root
[UiPanel]
    anchor = "top"
    position = (0, -16)
    size_ratio = (0.96, 0.09)
    min_h = 72
    max_h = 96
    fill = "#202838"
    stroke = "#516071"
    corner_radius = 16
    padding = (18, 12, 18, 12)
[/UiPanel]
[/top_bar]

[title_label]
parent = top_bar
[UiLabel]
    anchor = "top"
    position = (0, -8)
    text = "UiTest: panels / layouts / anchors"
    font_size = 30
    color = "#F4F7FB"
    size = (720, 48)
[/UiLabel]
[/title_label]

[main_row]
parent = @root
[UiHLayout]
    anchor = "top"
    position = (0, -150)
    size_ratio = (0.96, 0.70)
    spacing = 72
    padding = (12, 12, 12, 12)
[/UiHLayout]
[/main_row]

[left_panel]
parent = main_row
[UiPanel]
    size = (380, 720)
    fill = "#1D2531"
    stroke = "#435066"
    corner_radius = 18
    padding = (14, 14, 14, 14)
[/UiPanel]
[/left_panel]

[left_stack]
parent = left_panel
[UiVLayout]
    size_ratio = (1.0, 1.0)
    spacing = 12
    padding = (12, 12, 12, 12)
[/UiVLayout]
[/left_stack]

[left_header]
parent = left_stack
[UiLabel]
    text = "VLayout / fill width"
    font_size = 24
    color = "#D8DEE9"
    size = (300, 44)
[/UiLabel]
[/left_header]

[left_button_a]
parent = left_stack
[UiButton]
    size = (260, 44)
    style = { fill = "#5E506A" stroke = "#A08DB1" }
    hover = {
        size = (270, 48)
        scale = (1.02, 1.02)
        rotation = 0.015
        style = { fill = "#756387" stroke = "#C0A8D0" }
    }
    pressed = {
        size = (250, 40)
        scale = (0.98, 0.98)
        rotation = -0.01
        style = { fill = "#483D52" stroke = "#8E7A9D" }
    }
[/UiButton]
[/left_button_a]

[left_button_a_label]
parent = left_button_a
[UiLabel]
    text = "Fixed 260x44"
    font_size = 18
    color = "#F4ECFA"
    size_ratio = (1.0, 1.0)
[/UiLabel]
[/left_button_a_label]

[left_button_b]
parent = left_stack
[UiButton]
    size = (320, 52)
    fill = "#6A4E4E"
    hover_fill = "#815F5F"
    pressed_fill = "#503B3B"
    stroke = "#B88B8B"
[/UiButton]
[/left_button_b]

[left_button_b_label]
parent = left_button_b
[UiLabel]
    text = "Wide 320x52"
    font_size = 19
    color = "#FFF0F0"
    size_ratio = (1.0, 1.0)
[/UiLabel]
[/left_button_b_label]

[left_note]
parent = left_stack
[UiLabel]
    text = "margin + padding sample"
    font_size = 18
    color = "#BFC7D5"
    size = (300, 36)
    margin = (4, 8, 4, 8)
[/UiLabel]
[/left_note]

[center_panel]
parent = main_row
[UiPanel]
    size = (780, 600)
    fill = "#1B2A2D"
    stroke = "#4F6E73"
    corner_radius = 18
    padding = (18, 18, 18, 18)
[/UiPanel]
[/center_panel]

[center_grid]
parent = center_panel
[UiGrid]
    size_ratio = (1.0, 1.0)
    columns = 3
    h_spacing = 16
    v_spacing = 16
    padding = (16, 16, 16, 16)
[/UiGrid]
[/center_grid]

[grid_a]
parent = center_grid
[UiPanel]
    size = (150, 110)
    fill = "#27454D"
    stroke = "#73A6B2"
    corner_radius = 14
    padding = (10, 10, 10, 10)
[/UiPanel]
[/grid_a]

[grid_a_stack]
parent = grid_a
[UiVLayout]
    size_ratio = (1.0, 1.0)
    spacing = 6
[/UiVLayout]
[/grid_a_stack]

[grid_a_title]
parent = grid_a_stack
[UiLabel]
    text = "Inventory"
    font_size = 17
    color = "#E8FAFF"
    size = (128, 26)
[/UiLabel]
[/grid_a_title]

[grid_a_slots]
parent = grid_a_stack
[UiGrid]
    size = (128, 58)
    columns = 4
    h_spacing = 6
    v_spacing = 6
[/UiGrid]
[/grid_a_slots]

[grid_a_slot_1]
parent = grid_a_slots
[UiPanel]
    size = (24, 24)
    fill = "#3F6D77"
    stroke = "#91D4E1"
    corner_radius = 7
[/UiPanel]
[/grid_a_slot_1]

[grid_a_slot_2]
parent = grid_a_slots
[UiPanel]
    size = (24, 24)
    fill = "#5A6F35"
    stroke = "#B8DC76"
    corner_radius = 7
[/UiPanel]
[/grid_a_slot_2]

[grid_a_slot_3]
parent = grid_a_slots
[UiPanel]
    size = (24, 24)
    fill = "#604A2A"
    stroke = "#D4A85F"
    corner_radius = 7
[/UiPanel]
[/grid_a_slot_3]

[grid_a_slot_4]
parent = grid_a_slots
[UiPanel]
    size = (24, 24)
    fill = "#4F415D"
    stroke = "#C09EDF"
    corner_radius = 7
[/UiPanel]
[/grid_a_slot_4]

[grid_b]
parent = center_grid
[UiPanel]
    size = (150, 110)
    fill = "#48603A"
    stroke = "#9BBE7D"
    corner_radius = 14
    padding = (10, 10, 10, 10)
[/UiPanel]
[/grid_b]

[grid_b_stack]
