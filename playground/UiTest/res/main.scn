    font_size = 18
    color = "#F6F0FF"
    size_ratio = (1.0, 1.0)
[/UiLabel]
[/right_chip_label_a]

[right_button]
parent = right_layout
[UiButton]
    pressed_signals = ["ui_right_button_pressed"]
    click_signals = ["ui_right_button_click", "ui_any_button_click"]
    size = (220, 48)
    fill = "#664F31"
    hover_fill = "#80643E"
    pressed_fill = "#4D3C25"
    stroke = "#C59B58"
    corner_radius = 14
[/UiButton]
[/right_button]

[right_button_label]
parent = right_button
[UiLabel]
    text = "Fit text"
    font_size = 18
    color = "#FFF1D8"
    size_ratio = (1.0, 1.0)
[/UiLabel]
[/right_button_label]

[right_text_box]
parent = right_layout
[UiTextBox]
    size = (260, 44)
    text = "edit me"
    placeholder = "single line"
    font_size = 18
    fill = "#2B3443"
    stroke = "#8CA0BF"
    focused_fill = "#1F2A39"
    focused_stroke = "#B4CBF0"
    text_padding = (10, 8, 10, 8)
    corner_radius = 10
[/UiTextBox]
[/right_text_box]

[right_text_block]
parent = right_layout
[UiTextBlock]
    size = (260, 118)
    text = "multi line\ntry arrows\ntry scroll"
    placeholder = "multi line"
    font_size = 17
    fill = "#2E2938"
    stroke = "#A18CC4"
    focused_fill = "#241F30"
    focused_stroke = "#C7B3E8"
    selection_color = "#5E7CE2AA"
    text_padding = (10, 8, 10, 8)
    corner_radius = 10
[/UiTextBlock]
[/right_text_block]

