[/UiHLayout]
[/grid_b_row]

[grid_b_primary]
parent = grid_b_row
[UiButton]
    size = (44, 44)
    fill = "#63804A"
    hover_fill = "#789B5A"
    pressed_fill = "#4E663A"
    stroke = "#C7E4A6"
    corner_radius = 12
[/UiButton]
[/grid_b_primary]

[grid_b_primary_label]
parent = grid_b_primary
[UiLabel]
    text = "A"
    font_size = 18
    color = "#F3FFE8"
    size_ratio = (1.0, 1.0)
[/UiLabel]
[/grid_b_primary_label]

[grid_b_secondary]
parent = grid_b_row
[UiButton]
    size = (44, 44)
    fill = "#526842"
    hover_fill = "#668152"
    pressed_fill = "#3F5033"
    stroke = "#A9CA87"
    corner_radius = 12
[/UiButton]
[/grid_b_secondary]

[grid_b_secondary_label]
parent = grid_b_secondary
[UiLabel]
    text = "B"
    font_size = 18
    color = "#F3FFE8"
    size_ratio = (1.0, 1.0)
[/UiLabel]
[/grid_b_secondary_label]

[grid_c]
parent = center_grid
[UiPanel]
    size = (150, 110)
    fill = "#303E58"
    stroke = "#8BA7E0"
    corner_radius = 14
    padding = (10, 10, 10, 10)
[/UiPanel]
[/grid_c]

[grid_c_layout]
parent = grid_c
