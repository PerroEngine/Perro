# Perro material profile (.pmat)

# Base/PBR factors
base_color_factor = (0.1, 0.5, 0.2, 1.0)
metallic_factor = 1.0
roughness_factor = 0.3

# Texture slots (material-local indices)
base_color_texture = 0
metallic_roughness_texture = 1
normal_texture = 2
occlusion_texture = 3
emissive_texture = 4

# Extra controls
occlusion_strength = 1.0
emissive_factor = (0.0, 0.0, 0.0)
normal_scale = 1.0

alpha_mode = OPAQUE
alpha_cutoff = 0.5
double_sided = false
