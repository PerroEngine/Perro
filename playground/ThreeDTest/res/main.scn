@root = main

[main]
[Node3D]
    position = (0, 0, 0)
[/Node3D]
[/main]

[mesh1]
parent = @root
script = "res://scripts/script.rs"

[MeshInstance3D]
    mesh = "__cube__"
    material = {
        base_color_factor = (1.0, 0.2, 0.2, 1.0)
        metallic_factor = 0.0
        roughness_factor = 0.8
        emissive_factor = (0.0, 0.0, 0.0)
        alpha_mode = OPAQUE
        double_sided = false
    }
    [Node3D]
        position = (0, 0, 0)
        scale = (15,15,15)
    [/Node3D]
[/MeshInstance3D]

[/mesh1]


