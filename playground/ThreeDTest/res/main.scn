@root = main

[main]
[Node3D]
    position = (0, 0, 0)
[/Node3D]
[/main]

[mesh1]
parent = @root
script = "res://scripts/script.rs"
[MeshInstance3D]
    mesh = "__cube__"
    material = {
        type = standard
        base_color_factor = (1.0, 0.2, 0.2, 1.0)
        metallic_factor = 0.15
        roughness_factor = 0.75
        emissive_factor = (0.02, 0.0, 0.0)
        alpha_mode = OPAQUE
        double_sided = false
    }
    [Node3D]
        position = (0, 0, 0)
        scale = (15,15,15)
    [/Node3D]
[/MeshInstance3D]

[/mesh1]

[mesh1child]
parent = mesh1


[MeshInstance3D]
    mesh = "__cube__"
    material = {
        type = standard
        base_color_factor = (0.5, 0.5, 0.2, 1.0)
        metallic_factor = 0.5
        roughness_factor = 0.75
        emissive_factor = (0.02, 0.0, 0.0)
        alpha_mode = OPAQUE
        double_sided = false
    }
    [Node3D]
        position = (0, 2, 0)
        scale = (0.5,0.5,0.5)
    [/Node3D]
[/MeshInstance3D]

[/mesh1child]


[mesh2]
parent = @root
script = "res://scripts/script.rs"

[MeshInstance3D]
    mesh = "__sq_pyr__"
    material = {
        type = toon
        base_color_factor = (0.2, 0.8, 0.2, 1.0)
        band_count = 3
        rim_strength = 0.35
        outline_width = 0.02
        emissive_factor = (0.02, 0.05, 0.02)
        alpha_mode = OPAQUE
        double_sided = false
    }
    [Node3D]
        position = (40, 0, 0)
        scale = (15,15,15)
    [/Node3D]
[/MeshInstance3D]

[/mesh2]


