[mesh7]
parent = @root
script = "res://scripts/script.rs"

[MeshInstance3D]
    mesh = "__tri_prism__"
    material = "res://materials/crazy.pmat"
    [Node3D]
        position = (0, 0, 80)
        scale = (15,15,15)
    [/Node3D]
[/MeshInstance3D]

[/mesh7]


[mesh8]
parent = @root
script = "res://scripts/script.rs"

[MeshInstance3D]
    mesh = "__capsule__"
    material = {
    type = "custom"
    shader_path = "res://shaders/test_shader.wgsl"
    base_color_factor = (0.1, 0.1, 0.12, 1.0)
    emissive_factor = (0.2, 0.05, 0.35)
    alpha_mode = "OPAQUE"
    double_sided = false
    params = {
        freq = (0.35, 0.6, 0.9)
        warp = 2.5
        tint = (0.9, 0.6, 1.0, 1.0)
        glow = 0.4
    }
}

    [Node3D]
        position = (40, 0, 80)
        scale = (15,15,15)
    [/Node3D]
[/MeshInstance3D]

[/mesh8]


[rootOfSecondScene]
parent = @root
root_of = "res://second.scn"

    [Node3D]
        position = (25, 25, 0)
    [/Node3D]


[/rootOfSecondScene]

[rootOfSecondScene2]
parent = @root
root_of = "res://second.scn"

    [Node3D]
        position = (75, 50, 0)
    [/Node3D]


[/rootOfSecondScene2]


[camera]
parent = @root
script = "res://scripts/camera.rs"
script_vars = {"mesh": mesh8, "print_name": "Bob"}
    [Camera3D]
        active = true
       

        [Node3D]
            position = (50, 0, 120)
        [/Node3D]
    [/Camera3D]
[/camera]

[sun]
parent = @root

[RayLight3D]
    color = (1.0, 0.98, 0.92)
    intensity = 1.0
    active = true

    [Node3D]
        position = (0, 0, 0)
        rotation_deg = (0, 1, 0)
    [/Node3D]
[/RayLight3D]
[/sun]

[ambient]
parent = @root

[AmbientLight3D]
    color = (1.0, 1.0, 1.0)
    intensity = 0.3
[/AmbientLight3D]
[/ambient]

[sky3d]
parent = @root
    [Sky3D]
        day_colors = [
            (0.27, 0.79, 0.93),  # base
            (0.18, 0.72, 0.98),  # more blue / punchy sky
            (0.55, 0.90, 1.00)   # bright saturated highlight
        ]

        evening_colors = [
            (1.00, 0.45, 0.25),  # strong orange
            (1.00, 0.30, 0.55),  # saturated pink
            (0.60, 0.10, 0.50)   # deep magenta/purple
        ]

        night_colors = [
            (0.02, 0.03, 0.10),  # richer dark blue
            (0.05, 0.08, 0.25),  # saturated mid-night blue
            (0.15, 0.20, 0.45)   # stylized moonlit blue
        ]
        sky_angle = 35.0
        style = "realistic"
        time_of_day = 0.1
        time_paused = false
        time_scale = 5.0
        cloud_size = 0.68
        cloud_density = 0.74
        cloud_variance = 0.45
        wind_vector = (-0.8, 0.2)
        star_size = 5.0
        star_scatter = 0.7
        star_gleam = 0.8
        moon_size = 1.5
        sun_size = 1.75
        active = true
    [/Sky3D]
[/sky3d]
