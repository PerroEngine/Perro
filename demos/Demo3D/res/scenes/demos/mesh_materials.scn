        material = $var1
        flip_x = true
        flip_y = true
        flip_z = false
        [Node3D]
            position = (-2.8, 0.7, -3.0)
            scale = (1.15, 1.15, 1.15)
        [/Node3D]
    [/MeshInstance3D]
[/MirrorFlipXY]

