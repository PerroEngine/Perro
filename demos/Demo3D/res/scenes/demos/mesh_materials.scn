parent = @MeshMaterialsDemo
    [MeshInstance3D]
        material = $var1
        flip_x = true
        flip_y = false
        flip_z = true
        [Node3D]
            position = (2.8, 0.7, -3.0)
            scale = (1.15, 1.15, 1.15)
        [/Node3D]
    [/MeshInstance3D]
[/MirrorFlipXZ]

[MirrorFlipYZ]
parent = @MeshMaterialsDemo
    [MeshInstance3D]
        material = $var1
        flip_x = false
        flip_y = true
        flip_z = true
        [Node3D]
            position = (-2.8, 0.7, -4.4)
            scale = (1.15, 1.15, 1.15)
