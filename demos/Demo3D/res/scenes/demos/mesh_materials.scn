        material = $var1
        flip_x = false
        flip_y = false
        flip_z = true
        [Node3D]
            position = (2.8, 0.7, -1.6)
            scale = (1.15, 1.15, 1.15)
        [/Node3D]
    [/MeshInstance3D]
[/MirrorFlipZ]

