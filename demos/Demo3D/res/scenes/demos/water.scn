$root = @WaterDemo

[WaterDemo]
script = "res://scripts/water_demo.rs"
    [Node3D]
        position = (0, 0, 0)
    [/Node3D]
[/WaterDemo]

[DemoCamera]
parent = @WaterDemo
script = "res://scripts/demo_freecam_3d.rs"
script_vars = {
    yaw = 0.0
    pitch = -0.18
    speed = 12.0
}
    [Camera3D]
        active = true
        perspective_fov_y_degrees = 68.0
        [Node3D]
            position = (0, 5, 18)
            rotation = (-0.09, 0.0, 0.0, 0.996)
        [/Node3D]
    [/Camera3D]
[/DemoCamera]

[Projectiles]
parent = @WaterDemo
    [Node3D]
    [/Node3D]
[/Projectiles]

[Ambient]
parent = @WaterDemo
    [AmbientLight3D]
        color = (0.58, 0.70, 0.90)
        intensity = 0.38
    [/AmbientLight3D]
[/Ambient]

[Sun]
parent = @WaterDemo
    [RayLight3D]
        color = (1.0, 0.94, 0.82)
        intensity = 2.4
        [Node3D]
            rotation_deg = (-48, 28, 0)
        [/Node3D]
    [/RayLight3D]
[/Sun]

[BedCenter]
parent = @WaterDemo
    [MeshInstance3D]
        mesh = "__cube__"
        material = { type = "standard" base_color_factor = (0.22, 0.25, 0.20, 1.0) roughness_factor = 0.95 metallic_factor = 0.0 alpha_mode = "OPAQUE" double_sided = false }
        [Node3D]
            position = (0, -1.25, 0)
            scale = (12, 0.18, 12)
        [/Node3D]
    [/MeshInstance3D]
[/BedCenter]

