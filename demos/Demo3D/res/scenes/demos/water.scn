[Water]
parent = @WaterDemo
    [WaterBody3D]
        shape = { type = "cube" size = (500, 35, 500) }
        base_fidelity = 1
        depth = 2.0
        flow = (0.10, 0.03)
        wind = (0.8, 0.2)
        idle_mode = "chop"
        wave_speed = 0.38
        wave_scale = 0.55
        damping = 0.988
        buoyancy = 1.1
        drag = 0.36
        wake_strength = 1.20
        foam_strength = 0.72
        coastline = { foam_color = (0.68, 0.86, 0.92, 0.72) foam_strength = 0.52 foam_width = 1.65 cutoff_softness = 0.45 wave_reflection = 0.42 wave_damping = 0.48 edge_noise = 0.06 }
        shallow_color = (0.04, 0.25, 0.34, 0.95)
        deep_color = (0.005, 0.035, 0.15, 0.99)
        [Node3D]
            position = (0, 0, 0)
        [/Node3D]
    [/WaterBody3D]
[/Water]
