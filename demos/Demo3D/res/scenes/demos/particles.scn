[ShockwaveRingEmitter]
parent = @ParticlesDemo
    [ParticleEmitter3D]
        active = true
        looping = true
        prewarm = true
        spawn_rate = 78.0
        seed = 144.0
        params = (1.0, 0.9, 0.0, 0.0)
        profile = "res://particles/shockwave_ring.ppart"
        sim_mode = default
        render_mode = point
        [Node3D]
            position = (5.8, 0.2, 2.2)
        [/Node3D]
    [/ParticleEmitter3D]
