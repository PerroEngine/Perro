$root = @ParticlesDemo

[ParticlesDemo]
script = "res://scripts/particles_demo.rs"
    [Node3D/]
[/ParticlesDemo]

[DemoCamera]
parent = @ParticlesDemo
script = "res://scripts/demo_freecam_3d.rs"
script_vars = {
    yaw = 0.0,
    pitch = -0.12,
    speed = 10.0
}
    [Camera3D]
        active = true
        perspective_fov_y_degrees = 70.0
        [Node3D]
            position = (0.0, 5.2, 15.0)
            rotation = (-0.1, 0.0, 0.0, 0.995)
        [/Node3D]
    [/Camera3D]
[/DemoCamera]

[Ambient]
parent = @ParticlesDemo
    [AmbientLight3D]
        color = (0.32, 0.38, 0.52)
        intensity = 0.26
    [/AmbientLight3D]
[/Ambient]

[SunRay]
parent = @ParticlesDemo
    [RayLight3D]
        color = (1.0, 0.94, 0.84)
        intensity = 1.6
        cast_shadows = true
        [Node3D]
            position = (0.0, 12.0, 0.0)
            rotation_deg = (-72.0, -18.0, 0.0)
        [/Node3D]
    [/RayLight3D]
[/SunRay]

[Fill]
parent = @ParticlesDemo
    [PointLight3D]
        color = (0.3, 0.72, 1.0)
        intensity = 3.6
        radius = 10.0
        [Node3D]
            position = (2.5, 3.5, 0.5)
        [/Node3D]
    [/PointLight3D]
[/Fill]

[WarmFill]
parent = @ParticlesDemo
    [PointLight3D]
        color = (1.0, 0.45, 0.18)
        intensity = 1.8
        radius = 7.0
        [Node3D]
            position = (-4.0, 2.5, 2.0)
        [/Node3D]
    [/PointLight3D]
[/WarmFill]

[Floor]
parent = @ParticlesDemo
    [MeshInstance3D]
        mesh = "__cube__"
        material = {
            type = "standard",
            base_color_factor = (0.08, 0.09, 0.11, 1.0),
            roughness_factor = 0.92,
            metallic_factor = 0.0,
            alpha_mode = "OPAQUE",
            double_sided = false
        }
        [Node3D]
            position = (0.0, -0.15, 0.0)
            scale = (18.0, 0.1, 11.0)
        [/Node3D]
    [/MeshInstance3D]
[/Floor]

[PortalRig]
parent = @ParticlesDemo
    [Node3D]
        position = (0.0, 1.3, 0.0)
    [/Node3D]
[/PortalRig]

[PortalRigPlayer]
parent = @ParticlesDemo
    [AnimationPlayer]
        animation = "res://animations/particle_emitter_orbit.panim"
        bindings = { EmitterRig = @PortalRig }
        playback = loop
        speed = 0.65
        paused = false
    [/AnimationPlayer]
[/PortalRigPlayer]

[PortalVortexEmitter]
parent = @PortalRig
    [ParticleEmitter3D]
        active = true
        looping = true
        prewarm = true
        spawn_rate = 95.0
        seed = 7.0
        params = (1.1, 0.3, 0.8, 0.7)
        profile = "res://particles/portal_vortex.ppart"
        sim_mode = default
        render_mode = billboard
        [Node3D]
            position = (0.0, 0.0, 0.0)
        [/Node3D]
    [/ParticleEmitter3D]
[/PortalVortexEmitter]

[FireEmitter]
parent = @ParticlesDemo
    [ParticleEmitter3D]
        active = true
        looping = true
        prewarm = true
        spawn_rate = 76.0
        seed = 12.0
        params = (1.0, 2.2, 1.4, 0.0)
        profile = "res://particles/fire_spiral.ppart"
        sim_mode = default
        render_mode = billboard
        [Node3D]
            position = (-5.8, 0.2, -2.0)
        [/Node3D]
    [/ParticleEmitter3D]
[/FireEmitter]

[SparkEmitter]
parent = @ParticlesDemo
    [ParticleEmitter3D]
        active = true
        looping = true
        prewarm = true
        spawn_rate = 62.0
        seed = 41.0
        params = (0.8, 0.9, 0.6, 0.0)
        profile = "res://particles/spark_orbit.ppart"
        sim_mode = default
        render_mode = point
        [Node3D]
            position = (-2.9, 0.5, -2.2)
        [/Node3D]
    [/ParticleEmitter3D]
[/SparkEmitter]

