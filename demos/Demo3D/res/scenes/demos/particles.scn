        active = true
        looping = true
        prewarm = true
        spawn_rate = 70.0
        seed = 25.0
        params = (1.6, 1.1, 0.8, 0.0)
        profile = "res://particles/ember_fountain.ppart"
        sim_mode = default
        render_mode = billboard
        [Node3D]
            position = (2.9, 0.15, -2.0)
        [/Node3D]
    [/ParticleEmitter3D]
[/EmberFountainEmitter]

