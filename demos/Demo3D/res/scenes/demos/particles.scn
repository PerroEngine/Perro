        active = true
        looping = true
        prewarm = true
        spawn_rate = 42.0
        seed = 58.0
        params = (0.4, 1.0, 0.8, 0.0)
        profile = "res://particles/ice_mist.ppart"
        sim_mode = default
        render_mode = billboard
        [Node3D]
            position = (-5.8, 0.2, 2.4)
        [/Node3D]
    [/ParticleEmitter3D]
[/IceMistEmitter]

