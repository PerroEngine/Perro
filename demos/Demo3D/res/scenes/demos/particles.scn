parent = @ParticlesDemo
    [ParticleEmitter3D]
        active = true
        looping = true
        prewarm = true
        spawn_rate = 82.0
        seed = 77.0
        params = (1.0, 0.8, 1.3, 0.0)
        profile = "res://particles/laser_rain.ppart"
        sim_mode = default
        render_mode = point
        [Node3D]
            position = (-2.9, 2.3, 2.2)
        [/Node3D]
    [/ParticleEmitter3D]
[/LaserRainEmitter]

[OrbitRibbonEmitter]
parent = @ParticlesDemo
    [ParticleEmitter3D]
        active = true
        looping = true
        prewarm = true
        spawn_rate = 72.0
        seed = 103.0
        params = (1.2, 0.8, 0.9, 0.0)
        profile = "res://particles/orbit_ribbon.ppart"
        sim_mode = default
        render_mode = billboard
        [Node3D]
            position = (2.9, 0.8, 2.1)
        [/Node3D]
    [/ParticleEmitter3D]
