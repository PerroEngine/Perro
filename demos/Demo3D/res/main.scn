$root = @main

[main]
script = "res://scripts/demo_manager.rs"
    [Node3D]
        position = (0, 0, 0)
    [/Node3D]
[/main]

[demo_ui_root]
    [UiBox]
        anchor = "center"
        position_ratio = (0.5, 0.5)
        size_ratio = (1.0, 1.0)
        input_enabled = false
        mouse_filter = "pass"
    [/UiBox]
[/demo_ui_root]
