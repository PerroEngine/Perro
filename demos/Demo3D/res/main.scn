$root = @main

[main]
script = "res://scripts/demo_manager.rs"
script_vars = { demo_ui_root = @demo_ui_root }
    [Node3D]
        position = (0.0, 0.0, 0.0)
    [/Node3D]
[/main]

[demo_ui_root]
    [UiNode]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        input_enabled = false
        mouse_filter = "pass"
    [/UiNode]
[/demo_ui_root]
