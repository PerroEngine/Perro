{
  "rust-analyzer.cargo.buildScripts.enable": true,
  "rust-analyzer.cargo.extraEnv": {
    "RUSTFLAGS": "--cfg rust_analyzer"
  },
  "rust-analyzer.cargo.targetDir": "${workspaceFolder}/target",
  "rust-analyzer.check.command": "check",
  "rust-analyzer.checkOnSave": true,
  "rust-analyzer.diagnostics.enable": true,
  "rust-analyzer.linkedProjects": [
    "Cargo.toml",
    "playground/ThreeDTest/.perro/scripts/Cargo.toml",
    "playground/TwoDTest/.perro/scripts/Cargo.toml",
    "playground/Skeletal/.perro/scripts/Cargo.toml"
  ],
  "rust-analyzer.procMacro.enable": true,
  "rust-analyzer.vfs.extraIncludes": [
    "${workspaceFolder}/playground/ThreeDTest/res/",
    "${workspaceFolder}/playground/TwoDTest/res/",
    "${workspaceFolder}/playground/Skeletal/res/"
  ]
}
