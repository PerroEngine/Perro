$root = @editor_root

[editor_root]
script = "res://scripts/editor/main.rs"
    [UiPanel]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        style = {
            fill = "#171A1F",
            stroke = "#00000000",
            stroke_width = 0.0,
            radius = 0.0
        }
    [/UiPanel]
[/editor_root]

[project_manager]
parent = @editor_root
    [UiVLayout]
        anchor = "center"
        size_ratio = (0.62, 0.76)
        h_align = "fill"
        v_align = "start"
        spacing = 0.008
        padding = (0.02, 0.018)
        style = {
            fill = "#20252C",
            stroke = "#3B4450",
            stroke_width = 1.0,
            radius = 0.018
        }
    [/UiVLayout]
[/project_manager]

[project_manager_title]
parent = @project_manager
    [UiLabel]
        size_ratio = (1.0, 0.072)
        text = "Perro Project Manager"
        text_size_ratio = 0.46
        color = "#D7DBE0"
        h_align = "start"
        style = {
            fill = "#262C35",
            stroke = "#4D84D1",
            stroke_width = 1.0,
            radius = 0.018
        }
    [/UiLabel]
[/project_manager_title]

[project_manager_subtitle]
parent = @project_manager
    [UiLabel]
        size_ratio = (1.0, 0.038)
        text = "Open recent work or start a new game"
        text_size_ratio = 0.345
        color = "#8993A0"
        h_align = "start"
    [/UiLabel]
[/project_manager_subtitle]

[project_manager_recent_title]
parent = @project_manager
    [UiLabel]
        size_ratio = (1.0, 0.04)
        text = "Recent Projects"
        text_size_ratio = 0.431
        color = "#B0B8C3"
        h_align = "start"
    [/UiLabel]
[/project_manager_recent_title]

[manager_recent_0]
parent = @project_manager
    [UiButton]
        size_ratio = (1.0, 0.058)
        click_signals = ["editor_recent_0"]
        style = {
            fill = "#262C35",
            stroke = "#3B4450",
            stroke_width = 1.0,
            radius = 0.012
        }
        hover = { style = { fill = "#353D48", stroke = "#566273", stroke_width = 1.0, radius = 0.012 } }
        pressed = { style = { fill = "#29405F", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.012 } }
    [/UiButton]
[/manager_recent_0]

[manager_recent_0_label]
parent = @manager_recent_0
    [UiLabel]
        size_ratio = (0.96, 1.0)
        text = "-"
        text_size_ratio = 0.431
        color = "#D7DBE0"
        h_align = "start"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/manager_recent_0_label]

[manager_recent_1]
parent = @project_manager
    [UiButton]
        size_ratio = (1.0, 0.058)
        click_signals = ["editor_recent_1"]
        style = {
            fill = "#262C35",
            stroke = "#3B4450",
            stroke_width = 1.0,
