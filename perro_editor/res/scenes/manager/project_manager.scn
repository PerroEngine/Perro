[project_manager_create_title]
parent = @project_manager
    [UiLabel]
        size_ratio = (1.0, 0.04)
        text = "Create Project"
        text_size_ratio = 0.431
        color = "#B0B8C3"
        h_align = "start"
    [/UiLabel]
[/project_manager_create_title]

[create_name_box]
parent = @project_manager
    [UiTextBox]
        size_ratio = (1.0, 0.06)
        text = "NewGame"
        placeholder = "Project name"
        text_size_ratio = 0.431
        color = "#D7DBE0"
        placeholder_color = "#8993A0"
        style = {
            fill = "#1B1E24",
            stroke = "#3B4450",
            stroke_width = 1.0,
            radius = 0.012
        }
        focused_style = {
            fill = "#1B1E24",
            stroke = "#6BA0EA",
            stroke_width = 1.0,
            radius = 0.012
        }
    [/UiTextBox]
[/create_name_box]

[create_location_row]
parent = @project_manager
    [UiHLayout]
        size_ratio = (1.0, 0.062)
        h_align = "fill"
        v_align = "center"
        spacing = 0.012
    [/UiHLayout]
[/create_location_row]

[create_location_label]
parent = @create_location_row
    [UiLabel]
        size_ratio = (0.66, 0.82)
        text = "Location: not set"
        text_size_ratio = 0.374
        color = "#B0B8C3"
        h_align = "start"
        style = {
            fill = "#1B1E24",
            stroke = "#3B4450",
            stroke_width = 1.0,
            radius = 0.012
        }
    [/UiLabel]
[/create_location_label]

[manager_choose_location_button]
parent = @create_location_row
    [UiButton]
        size_ratio = (0.16, 0.82)
        click_signals = ["editor_manager_choose_location"]
        style = {
            fill = "#2A2F36",
            stroke = "#343A43",
            stroke_width = 1.0,
            radius = 0.006
        }
        hover = { style = { fill = "#323842", stroke = "#4A525D", stroke_width = 1.0, radius = 0.006 } }
        pressed = { style = { fill = "#4D84D1", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.006 } }
    [/UiButton]
[/manager_choose_location_button]

[manager_choose_location_label]
parent = @manager_choose_location_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Pick"
        text_size_ratio = 0.402
        color = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/manager_choose_location_label]

[manager_create_button]
parent = @create_location_row
    [UiButton]
        size_ratio = (0.16, 0.82)
        click_signals = ["editor_manager_create"]
        style = {
            fill = "#D98B3A",
            stroke = "#D98B3A",
            stroke_width = 1.0,
            radius = 0.006
        }
        hover = { style = { fill = "#E59A4B", stroke = "#E59A4B", stroke_width = 1.0, radius = 0.006 } }
        pressed = { style = { fill = "#F2A85C", stroke = "#F2A85C", stroke_width = 1.0, radius = 0.006 } }
    [/UiButton]
[/manager_create_button]

[manager_create_label]
parent = @manager_create_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Create"
        text_size_ratio = 0.402
        color = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/manager_create_label]

[project_manager_actions]
parent = @project_manager
    [UiHLayout]
        size_ratio = (1.0, 0.062)
        h_align = "end"
        v_align = "center"
        spacing = 0.012
    [/UiHLayout]
[/project_manager_actions]

[manager_browse_button]
parent = @project_manager_actions
    [UiButton]
        size_ratio = (0.34, 0.82)
        click_signals = ["editor_manager_browse"]
        style = {
            fill = "#2A2F36",
            stroke = "#343A43",
            stroke_width = 1.0,
            radius = 0.006
        }
        hover = { style = { fill = "#323842", stroke = "#4A525D", stroke_width = 1.0, radius = 0.006 } }
        pressed = { style = { fill = "#4D84D1", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.006 } }
    [/UiButton]
[/manager_browse_button]

[manager_browse_label]
parent = @manager_browse_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Browse"
        text_size_ratio = 0.402
        color = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/manager_browse_label]

[manager_close_button]
parent = @project_manager_actions
    [UiButton]
        size_ratio = (0.26, 0.82)
        click_signals = ["editor_manager_close"]
        style = {
            fill = "#2A2F36",
            stroke = "#343A43",
            stroke_width = 1.0,
            radius = 0.006
        }
        hover = { style = { fill = "#323842", stroke = "#4A525D", stroke_width = 1.0, radius = 0.006 } }
        pressed = { style = { fill = "#4D84D1", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.006 } }
    [/UiButton]
[/manager_close_button]

[manager_close_label]
parent = @manager_close_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Close"
        text_size_ratio = 0.402
        color = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/manager_close_label]

