$root = @editor_root
$bg = { fill: "#20242B", stroke: "#00000000", stroke_width: 0.0, radius: 0.0 }
$bar = { fill: "#272D36", stroke: "#00000000", stroke_width: 0.0, radius: 0.0 }
$panel = { fill: "#303742", stroke: "#4D5665", stroke_width: 1.0, radius: 0.025 }
$panel_dark = { fill: "#252B34", stroke: "#4D5665", stroke_width: 1.0, radius: 0.025 }
$btn = { fill: "#3D4654", stroke: "#00000000", stroke_width: 0.0, radius: 0.08 }
$btn_hot = { style: { fill: "#4A5668", stroke: "#00000000", stroke_width: 0.0, radius: 0.08 } }
$btn_down = { style: { fill: "#59677D", stroke: "#00000000", stroke_width: 0.0, radius: 0.08 } }
$row = { fill: "#39414E", stroke: "#00000000", stroke_width: 0.0, radius: 0.04 }
$row_sel = { fill: "#54657A", stroke: "#93C5FD", stroke_width: 1.0, radius: 0.04 }
$field = { fill: "#242A33", stroke: "#404A58", stroke_width: 1.0, radius: 0.04 }
$field_focus = { fill: "#242A33", stroke: "#93C5FD", stroke_width: 1.0, radius: 0.04 }

[editor_root]
    [UiPanel]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        style = $bg
    [/UiPanel]
[/editor_root]

[root_stack]
parent = @editor_root
    [UiVLayout]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.0
    [/UiVLayout]
[/root_stack]

[top_bar]
parent = @root_stack
    [UiHLayout]
        size_ratio = (1.0, 0.055)
        h_align = "fill"
        v_align = "center"
        spacing = 0.006
        padding = (0.006, 0.006)
        style = $bar
    [/UiHLayout]
[/top_bar]

[open_project_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.105, 0.78)
        click_signals = ["editor_open_project"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/open_project_button]

[open_project_label]
parent = @open_project_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Open Project"
        text_size_ratio = 0.295
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/open_project_label]

[save_scene_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.085, 0.78)
        click_signals = ["editor_save_scene"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/save_scene_button]

[save_scene_label]
parent = @save_scene_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Save"
        text_size_ratio = 0.312
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/save_scene_label]

[add_node_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.095, 0.78)
        click_signals = ["editor_add_node"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/add_node_button]

[add_node_label]
parent = @add_node_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Add Node"
        text_size_ratio = 0.279
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/add_node_label]

[mode_ui_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.055, 0.78)
        click_signals = ["editor_mode_ui"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/mode_ui_button]

[mode_ui_label]
parent = @mode_ui_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "UI"
        text_size_ratio = 0.344
        color = "#86EFAC"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/mode_ui_label]

[mode_2d_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.055, 0.78)
