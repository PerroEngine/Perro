        text_size_ratio = 0.344
        color = "#FDBA74"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/mode_3d_label]

[project_status]
parent = @top_bar
    [UiLabel]
        size_ratio = (0.52, 0.78)
        text = "No project"
        text_size_ratio = 0.262
        color = "#D1D5DB"
        h_align = "start"
        v_align = "center"
    [/UiLabel]
[/project_status]

[main_split]
parent = @root_stack
    [UiHLayout]
        size_ratio = (1.0, 0.885)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.004
        padding = (0.004, 0.004)
    [/UiHLayout]
[/main_split]

[left_panel]
parent = @main_split
    [UiVLayout]
        size_ratio = (0.20, 1.0)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.006
        style = $panel
    [/UiVLayout]
[/left_panel]

[scene_tree_title]
parent = @left_panel
    [UiLabel]
        size_ratio = (1.0, 0.055)
        text = "Scene"
        text_size_ratio = 0.344
        color = "#F3F4F6"
    [/UiLabel]
[/scene_tree_title]

[scene_rows]
parent = @left_panel
    [UiList]
        size_ratio = (1.0, 0.43)
        h_align = "fill"
        v_align = "start"
        indent = 18.0
        v_spacing = 0.006
        padding = (0.035, 0.012)
    [/UiList]
[/scene_rows]

