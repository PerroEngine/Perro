        pressed = { style = { fill = "#4D84D1", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.045 } }
    [/UiButton]
[/activity_scene_button]

[activity_scene_icon]
parent = @activity_scene_button
    [UiImage]
        size_ratio = (0.74, 0.74)
        texture = "res://icons/activity/scene.png"
        scale_mode = "fit"
        tint = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiImage]
[/activity_scene_icon]

