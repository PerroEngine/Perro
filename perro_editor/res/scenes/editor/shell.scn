$root = @editor_root
$bg = { fill: "#1B1D23", stroke: "#00000000", stroke_width: 0.0, radius: 0.0 }
$bar = { fill: "#24272E", stroke: "#121419", stroke_width: 1.0, radius: 0.018 }
$panel = { fill: "#24272E", stroke: "#343842", stroke_width: 1.0, radius: 0.024 }
$panel_dark = { fill: "#1F2229", stroke: "#343842", stroke_width: 1.0, radius: 0.024 }
$inspector_panel = { fill: "#20242B", stroke: "#4A5568", stroke_width: 1.0, radius: 0.028 }
$inspector_header = { fill: "#151A21", stroke: "#478CBF", stroke_width: 1.0, radius: 0.12 }
$viewport = { fill: "#181A20", stroke: "#3B414D", stroke_width: 1.0, radius: 0.03 }
$btn = { fill: "#2D323C", stroke: "#3B414D", stroke_width: 1.0, radius: 1.0 }
$btn_hot = { style: { fill: "#38404C", stroke: "#566174", stroke_width: 1.0, radius: 1.0 } }
$btn_down = { style: { fill: "#478CBF", stroke: "#6BB6E8", stroke_width: 1.0, radius: 1.0 } }
$tab = { fill: "#2D323C", stroke: "#3B414D", stroke_width: 1.0, radius: 0.35 }
$tab_hot = { style: { fill: "#38404C", stroke: "#566174", stroke_width: 1.0, radius: 0.35 } }
$tab_down = { style: { fill: "#478CBF", stroke: "#6BB6E8", stroke_width: 1.0, radius: 0.35 } }
$row = { fill: "#00000000", stroke: "#00000000", stroke_width: 0.0, radius: 0.0 }
$row_sel = { fill: "#478CBF", stroke: "#6BB6E8", stroke_width: 1.0, radius: 0.0 }
$field = { fill: "#191B20", stroke: "#3B414D", stroke_width: 1.0, radius: 0.10 }
$field_focus = { fill: "#191B20", stroke: "#6BB6E8", stroke_width: 1.0, radius: 0.10 }

[editor_root]
    [UiPanel]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        style = $bg
    [/UiPanel]
[/editor_root]

[root_stack]
parent = @editor_root
    [UiVLayout]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.0
    [/UiVLayout]
[/root_stack]

[top_bar]
parent = @root_stack
    [UiHLayout]
        size_ratio = (1.0, 0.034)
        h_align = "fill"
        v_align = "center"
        spacing = 0.002
        padding = (0.003, 0.004)
        style = $bar
    [/UiHLayout]
[/top_bar]

[open_project_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.058, 0.78)
        click_signals = ["editor_open_project"]
        style = $tab
        hover = $tab_hot
        pressed = $tab_down
    [/UiButton]
[/open_project_button]

[open_project_label]
parent = @open_project_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Project"
        text_size_ratio = 0.26
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/open_project_label]

[save_scene_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.046, 0.78)
        click_signals = ["editor_save_scene"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/save_scene_button]

[save_scene_label]
parent = @save_scene_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Save"
        text_size_ratio = 0.23
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/save_scene_label]

[add_node_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.056, 0.78)
        click_signals = ["editor_add_node"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/add_node_button]

[add_node_label]
parent = @add_node_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "+ Node"
        text_size_ratio = 0.26
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/add_node_label]

[mode_ui_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.035, 0.78)
        click_signals = ["editor_mode_ui"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/mode_ui_button]

[mode_ui_label]
parent = @mode_ui_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "UI"
        text_size_ratio = 0.30
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/mode_ui_label]

[mode_2d_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.035, 0.78)
        click_signals = ["editor_mode_2d"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/mode_2d_button]

[mode_2d_label]
parent = @mode_2d_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "2D"
        text_size_ratio = 0.30
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/mode_2d_label]

[mode_3d_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.035, 0.78)
        click_signals = ["editor_mode_3d"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/mode_3d_button]

[mode_3d_label]
parent = @mode_3d_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "3D"
        text_size_ratio = 0.30
        color = "#F3F4F6"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/mode_3d_label]

[project_status]
parent = @top_bar
    [UiLabel]
        size_ratio = (0.72, 0.78)
        text = "No project"
        text_size_ratio = 0.19
        color = "#D1D5DB"
        h_align = "start"
        v_align = "center"
    [/UiLabel]
[/project_status]

[main_split]
parent = @root_stack
    [UiHLayout]
        size_ratio = (1.0, 0.944)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.004
        padding = (0.004, 0.004)
    [/UiHLayout]
[/main_split]

[activity_bar]
parent = @main_split
    [UiVLayout]
        size_ratio = (0.024, 1.0)
        h_align = "fill"
        v_align = "start"
        spacing = 0.006
        padding = (0.008, 0.012)
        style = $panel_dark
    [/UiVLayout]
[/activity_bar]

[activity_scene_button]
parent = @activity_bar
    [UiButton]
        size_ratio = (1.0, 0.052)
        click_signals = ["editor_activity_scene"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/activity_scene_button]

[activity_scene_icon]
parent = @activity_scene_button
    [UiImage]
        size_ratio = (0.74, 0.74)
        texture = "res://icons/activity/scene.png"
        scale_mode = "fit"
        tint = "#FFFFFFFF"
        input_enabled = false
        mouse_filter = "pass"
    [/UiImage]
[/activity_scene_icon]

[activity_glb_button]
parent = @activity_bar
    [UiButton]
        size_ratio = (1.0, 0.052)
        click_signals = ["editor_activity_glb"]
        style = $btn
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/activity_glb_button]

[activity_glb_icon]
parent = @activity_glb_button
    [UiImage]
        size_ratio = (0.74, 0.74)
        texture = "res://icons/activity/glb.png"
        scale_mode = "fit"
        tint = "#B8C1CCFF"
        input_enabled = false
        mouse_filter = "pass"
    [/UiImage]
[/activity_glb_icon]

[left_panel]
parent = @main_split
    [UiVLayout]
        size_ratio = (0.108, 1.0)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.006
        style = $panel
    [/UiVLayout]
[/left_panel]

[scene_tree_title]
parent = @left_panel
    [UiLabel]
        size_ratio = (1.0, 0.04)
        text = "Scene"
        text_size_ratio = 0.24
        color = "#F3F4F6"
        h_align = "start"
        style = $bar
    [/UiLabel]
[/scene_tree_title]

[scene_filter_box]
parent = @left_panel
    [UiTextBox]
        size_ratio = (1.0, 0.044)
        text = ""
        placeholder = "Find node  @2d @3d @ui @mesh @anim"
        placeholder_color = "#94A3B8"
        text_size_ratio = 0.24
        text_changed_signals = ["editor_scene_filter"]
        style = $field
        focused_style = $field_focus
    [/UiTextBox]
[/scene_filter_box]

[scene_rows]
parent = @left_panel
    [UiVLayout]
        size_ratio = (1.0, 0.378)
        h_align = "fill"
        v_align = "start"
        spacing = 0.002
        padding = (0.018, 0.006)
    [/UiVLayout]
[/scene_rows]

[scene_row_0]
parent = @scene_rows
    [UiButton]
        size_ratio = (1.0, 0.062)
        click_signals = ["editor_select_scene_0"]
        style = $row
        hover = $btn_hot
        pressed = $btn_down
    [/UiButton]
[/scene_row_0]

[scene_row_0_label]
parent = @scene_row_0
    [UiLabel]
        size_ratio = (0.96, 1.0)
        text = "-"
        text_size_ratio = 0.30
        color = "#E5E7EB"
        h_align = "start"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
