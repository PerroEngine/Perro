        padding = (0.0025, 0.003)
    [/UiHLayout]
[/main_split]

[activity_bar]
parent = @main_split
    [UiVLayout]
        size_ratio = (0.03, 1.0)
        min_size_ratio = (0.9, 0.8)
        max_size_ratio = (1.25, 1.2)
        h_align = "fill"
        v_align = "start"
        spacing = 0.008
        padding = (0.012, 0.014)
        style = {
            fill = "#1D2229",
            stroke = "#3B4450",
            stroke_width = 1.0,
            radius = 0.006
        }
    [/UiVLayout]
[/activity_bar]

[activity_scene_button]
parent = @activity_bar
