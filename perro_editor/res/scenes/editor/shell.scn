        color = "#F3F4F6"
        h_align = "start"
        style = $bar
    [/UiLabel]
[/file_title]

[file_action_row]
parent = @left_panel
    [UiHLayout]
        visible = false
        size_ratio = (1.0, 0.0)
        h_align = "fill"
        v_align = "center"
        spacing = 0.006
        padding = (0.035, 0.0)
    [/UiHLayout]
[/file_action_row]

