[inspector_pick_popup]
parent = @editor_root
    [UiVLayout]
        anchor = "center"
        size_ratio = (0.3, 0.7)
        h_align = "fill"
        v_align = "start"
        spacing = 0.004
        padding = (0.018, 0.012)
        z_index = 200.0
        visible = false
        style = {
            fill = "#2A2F36",
            stroke = "#343A43",
            stroke_width = 1.0,
            radius = 0.006
        }
    [/UiVLayout]
[/inspector_pick_popup]

