$root = @editor_root

[editor_root]
    [UiPanel]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        style = {
            fill = "#171A1F",
            stroke = "#00000000",
            stroke_width = 0.0,
            radius = 0.0
        }
    [/UiPanel]
[/editor_root]

[root_stack]
parent = @editor_root
    [UiVLayout]
        anchor = "center"
        size_ratio = (1.0, 1.0)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.0
    [/UiVLayout]
[/root_stack]

[top_bar]
parent = @root_stack
    [UiHLayout]
        size_ratio = (1.0, 0.034)
        h_align = "fill"
        v_align = "center"
        spacing = 0.003
        padding = (0.006, 0.006)
        style = {
            fill = "#20252C",
            stroke = "#3B4450",
            stroke_width = 1.0,
            radius = 0.006
        }
    [/UiHLayout]
[/top_bar]

[open_project_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.058, 0.9)
        click_signals = ["editor_open_project"]
        style = {
            fill = "#2A2F36",
            stroke = "#4A525D",
            stroke_width = 1.0,
            radius = 0.035
        }
        hover = { style = { fill = "#323842", stroke = "#4A525D", stroke_width = 1.0, radius = 0.035 } }
        pressed = { style = { fill = "#4D84D1", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.035 } }
    [/UiButton]
[/open_project_button]

[open_project_label]
parent = @open_project_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Project"
        text_size_ratio = 0.374
        color = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/open_project_label]

[save_scene_button]
parent = @top_bar
    [UiButton]
        size_ratio = (0.046, 0.9)
        click_signals = ["editor_save_scene"]
        style = {
            fill = "#2A2F36",
            stroke = "#4A525D",
            stroke_width = 1.0,
            radius = 0.045
