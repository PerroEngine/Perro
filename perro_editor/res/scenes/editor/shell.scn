        v_align = "center"
    [/UiLabel]
[/project_status]

[main_split]
parent = @root_stack
    [UiHLayout]
        size_ratio = (1.0, 0.944)
        h_align = "fill"
        v_align = "fill"
        spacing = 0.0025
        padding = (0.0025, 0.003)
    [/UiHLayout]
[/main_split]

[activity_bar]
parent = @main_split
    [UiVLayout]
        size_ratio = (0.024, 1.0)
        h_align = "fill"
        v_align = "start"
        spacing = 0.006
        padding = (0.008, 0.012)
        style = {
            fill = "#23272D",
            stroke = "#343A43",
            stroke_width = 1.0,
            radius = 0.006
        }
    [/UiVLayout]
[/activity_bar]

[activity_scene_button]
parent = @activity_bar
