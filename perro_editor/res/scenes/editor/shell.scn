        size_ratio = (0.28, 0.9)
        click_signals = ["editor_inspector_pick_next"]
        style = {
            fill = "#2A2F36",
            stroke = "#4A525D",
            stroke_width = 1.0,
            radius = 0.045
        }
        hover = { style = { fill = "#323842", stroke = "#4A525D", stroke_width = 1.0, radius = 0.045 } }
        pressed = { style = { fill = "#4D84D1", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.045 } }
    [/UiButton]
[/inspector_pick_next_button]

[inspector_pick_next_label]
parent = @inspector_pick_next_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Next"
        text_size_ratio = 0.331
        color = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/inspector_pick_next_label]

[inspector_pick_cancel_button]
parent = @inspector_pick_popup
    [UiButton]
        size_ratio = (1.0, 0.052)
        click_signals = ["editor_inspector_pick_cancel"]
        style = {
            fill = "#2A2F36",
            stroke = "#4A525D",
            stroke_width = 1.0,
            radius = 0.045
        }
        hover = { style = { fill = "#323842", stroke = "#4A525D", stroke_width = 1.0, radius = 0.045 } }
        pressed = { style = { fill = "#4D84D1", stroke = "#6BA0EA", stroke_width = 1.0, radius = 0.045 } }
    [/UiButton]
[/inspector_pick_cancel_button]

[inspector_pick_cancel_label]
parent = @inspector_pick_cancel_button
    [UiLabel]
        size_ratio = (1.0, 1.0)
        text = "Cancel"
        text_size_ratio = 0.331
        color = "#D7DBE0"
        input_enabled = false
        mouse_filter = "pass"
    [/UiLabel]
[/inspector_pick_cancel_label]

