@root = preview_canvas

[preview_canvas]
script = "res://scripts/editor.rs"
[UiPanel]
    anchor = "center"
    position_ratio = (0.5, 0.5)
    size_ratio = (1.0, 1.0)
    scale = (0.5, 0.5)
    h_size = "fixed"
    v_size = "fixed"
    fill = "#101318"
    stroke = "#00000000"
[/UiPanel]

[/preview_canvas]
